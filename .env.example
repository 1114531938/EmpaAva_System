# EmpaAva local configuration. Copy this file to .env; never commit .env.
EMPAAVA_MODE=mock
AVATAR_SYSTEM_ROOT=.
PROJECT_ROOT=.
HOST=127.0.0.1
PORT=7861
EMPAAVA_CACHE_DIR=runtime/cache/downloads
EMPAAVA_MODEL_DIR=runtime/models
EMPAAVA_RUN_DIR=runtime/outputs
EMPAAVA_SEED=42

# Full mode only. Use an OpenAI-compatible endpoint/model.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=liquid/lfm-2.5-1.2b-instruct:free

# Full-mode worker ports.
TTS_WORKER_PORT=8788
AVAMERG_WORKER_PORT=8789
DEEPTALK_WORKER_PORT=8790
PERCEPTION_WORKER_PORT=8791
GAUSSIAN_RENDER_WORKER_PORT=8792
